# ============================================================
#  Bateu, Comprou — Configurações do Scraper
#  Copie este arquivo para .env e preencha seus dados
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua_anon_key_aqui

# --- Horários do Cron (formato HH:MM, fuso local) ---
CRON_HORA_1=07:00
CRON_HORA_2=19:00

# --- Configurações do Scraper ---
MIN_RATING=4.5          # Nota mínima dos produtos
MAX_PRODUCTS_PER_STORE=30  # Máximo de produtos por loja por varredura
HEADLESS=true           # true = sem abrir janela do browser

# --- Proxies (opcional, deixe em branco para não usar) ---
PROXY_URL=
